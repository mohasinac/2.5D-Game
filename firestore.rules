rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ── User profiles (auth roles) ─────────────────────────────────────────────
    match /users/{uid} {
      // Users can read/write their own doc (created on first sign-in)
      allow read, write: if isOwner(uid);
      // Admins can read and update any user doc (for role management)
      allow read: if isAdmin();
      // Admins can update role field on any user (but not delete docs)
      allow update: if isAdmin() && request.resource.data.keys().hasOnly(
        ["role", "email", "displayName", "updatedAt", "lastLoginAt", "createdAt", "photoURL"]
      );
    }

    // ── Core game data (admin write, authenticated read) ───────────────────────
    match /beyblade_stats/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /arenas/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /stadiums/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /settings/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Asset collections (admin write, authenticated read) ────────────────────
    match /arena_theme_assets/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /obstacle_assets/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /turret_assets/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /water_body_assets/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /portal_assets/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /sound_assets/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Game results ───────────────────────────────────────────────────────────
    match /matches/{id} {
      allow read: if isAuthenticated();
      // Server uses Admin SDK (bypasses rules). Direct client writes allowed for
      // authenticated users as a local fallback; primary writes are server-side.
      allow write: if isAuthenticated();
    }

    // ── Player stats / leaderboard ─────────────────────────────────────────────
    // Public read: leaderboard is visible without sign-in.
    // Writes: server Admin SDK only (bypasses rules). Client fallback requires auth.
    match /player_stats/{id} {
      allow read: if true;
      allow write: if isAuthenticated() && isOwner(id);
    }

    // ── Tournament system ──────────────────────────────────────────────────────
    match /tournaments/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /tournament_participants/{id} {
      allow read: if isAuthenticated();
      // Players register themselves; admins manage all
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /tournament_brackets/{id} {
      allow read: if isAuthenticated();
      // Bracket docs are written by server Admin SDK and admin UI only
      allow write: if isAdmin();
    }

    // ── 2.5D Part Library (admin write, authenticated read) ───────────────────
    match /bit_beast_parts/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /attack_ring_parts/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /weight_disk_parts/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /sub_parts/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /tip_parts/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /core_parts/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /casing_parts/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /beyblade_systems/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Catch-all: deny unauthenticated and unlisted paths ────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
