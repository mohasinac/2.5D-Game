# Client Environment Variables
# For LOCAL dev: create client/.env.local (gitignored) with VITE_GAME_SERVER_URL=ws://localhost:2567
# For PRODUCTION: set VITE_GAME_SERVER_URL in client/.env to your deployed server (wss://...)

# Colyseus Game Server WebSocket URL
VITE_GAME_SERVER_URL=ws://localhost:2567

# Firebase Web SDK Configuration
# Get from: Firebase Console → Project Settings → General → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
