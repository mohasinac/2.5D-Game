# Client Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Setup:
#   1. Copy this file to client/.env  (gitignored — stays on your machine)
#   2. Fill in the Firebase values below
#   3. Run `npm run dev:client` — connects to ws://localhost:2567 automatically
#
# Production (Vercel):
#   - client/.env.production (committed) overrides VITE_GAME_SERVER_URL to wss://...
#   - Firebase keys must be set as Vercel environment variables in the dashboard
#   - VITE_LOCAL is absent in .env.production → no LOCAL banner in prod builds
# ─────────────────────────────────────────────────────────────────────────────

# Marks this as a local dev build — shows an amber "LOCAL" banner in the UI
VITE_LOCAL=true

# Colyseus Game Server WebSocket URL — local default; .env.production overrides for Vercel
VITE_GAME_SERVER_URL=ws://localhost:2567

# Firebase Web SDK Configuration
# Get from: Firebase Console → Project Settings → General → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
