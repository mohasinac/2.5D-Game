{
  "name": "beyblade-game-server",
  "version": "1.0.0",
  "description": "Colyseus game server for Beyblade battles",
  "main": "lib/index.js",
  "scripts": {
    "start": "node lib/index.js",
    "build": "tsc",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon --exec ts-node src/index.ts",
    "dev:client": "cd client && npm run dev",
    "docker:build": "docker build --target production -t beyblade-server .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f server",
    "docker:dev": "concurrently \"npm run docker:up && npm run docker:logs\" \"npm run dev:client\"",
    "check": "node scripts/check.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rooms": "node scripts/test-rooms.js",
    "seed:beyblades": "node scripts/seed-beyblades.js",
    "seed:arenas": "node scripts/seed-arenas.js",
    "seed:all": "node scripts/seed-admin.js && node scripts/seed-beyblades.js && node scripts/seed-arenas.js",
    "deploy": "npm run deploy:client && npm run deploy:rules",
    "deploy:client": "cd client && npm run build && cd .. && firebase deploy --only hosting",
    "deploy:rules": "firebase deploy --only firestore:rules,firestore:indexes,storage",
    "loadtest": "colyseus-loadtest loadtest/example.ts --room tryout_room --numClients 2"
  },
  "author": "JustForView.in",
  "license": "MIT",
  "dependencies": {
    "@colyseus/monitor": "^0.15.0",
    "@colyseus/tools": "^0.15.0",
    "colyseus": "^0.15.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "firebase-admin": "^12.0.0",
    "matter-js": "^0.19.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@colyseus/loadtest": "^0.15.0",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/matter-js": "^0.19.6",
    "@types/node": "^24.10.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
