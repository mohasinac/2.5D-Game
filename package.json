{
  "name": "beyblade-game-server",
  "version": "1.0.0",
  "description": "Colyseus game server for Beyblade battles",
  "main": "lib/index.js",
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon --exec ts-node src/index.ts",
    "dev:client": "cd client && npm run dev",
    "dev:app": "next dev -p 3001",
    "build": "npm run build:server && npm run build:app",
    "build:server": "tsc",
    "build:app": "next build",
    "watch": "tsc -w",
    "start:app": "next start -p 3001",
    "start:all": "concurrently \"npm run start\" \"npm run start:app\"",
    "loadtest": "colyseus-loadtest loadtest/example.ts --room my_room --numClients 2"
  },
  "author": "JustForView.in",
  "license": "MIT",
  "dependencies": {
    "@colyseus/monitor": "^0.15.0",
    "@colyseus/tools": "^0.15.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@types/react": "^19.2.2",
    "autoprefixer": "^10.4.21",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "colyseus": "^0.15.0",
    "colyseus.js": "^0.16.22",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "firebase-admin": "^12.0.0",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.552.0",
    "matter-js": "^0.19.0",
    "next": "^16.0.1",
    "pixi.js": "^8.14.0",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.66.0",
    "react-hot-toast": "^2.6.0",
    "swr": "^2.3.6",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.16",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@colyseus/loadtest": "^0.15.0",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/matter-js": "^0.19.6",
    "@types/node": "^24.10.0",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.3"
  }
}
