# Server Environment Variables
# Copy to .env and fill in real values — never commit .env

# Colyseus Game Server
PORT=2567
NODE_ENV=development

# Firebase Admin SDK (service account) — get from Firebase Console → Project Settings → Service accounts
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Production deployment URL (Railway / other host) — used for CORS and external links
# Leave blank for local development
RAILWAY_URL=

# Optional: Redis for horizontal scaling (future)
# REDIS_URL=redis://localhost:6379
