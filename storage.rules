rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Beyblade sprites ────────────────────────────────────────────────────
    match /assets/beyblade_stats/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024  // 5 MB max
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Arena theme backgrounds ─────────────────────────────────────────────
    match /assets/arena_theme_assets/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Obstacle, turret, water body, portal sprites ────────────────────────
    match /assets/obstacle_assets/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /assets/turret_assets/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /assets/water_body_assets/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /assets/portal_assets/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Sound effects and music ─────────────────────────────────────────────
    match /assets/sound_assets/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 20 * 1024 * 1024  // 20 MB max for audio
                   && request.resource.contentType.matches('audio/.*');
    }

    // ── Stadium images ──────────────────────────────────────────────────────
    match /stadiums/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Catch-all: deny everything else ────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
