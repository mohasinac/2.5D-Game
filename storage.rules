rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Helper functions ────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      // Reads custom claim set by scripts/seed-admin.js
      // (admin.auth().setCustomUserClaims(uid, { admin: true })).
      // Avoids cross-service Firestore lookup — no extra IAM grant needed.
      return isAuthenticated() && request.auth.token.admin == true;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isAudio() {
      return request.resource.contentType.matches('audio/.*');
    }

    // Note: split create+update (need request.resource for size/type checks)
    // from delete (no request.resource — admin-only suffices).

    // ── Beyblade sprites (uploaded by admin, uploaded under beyblades/) ─────────
    match /beyblades/{allPaths=**} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin()
                            && request.resource.size < 5 * 1024 * 1024
                            && isImage();
      allow delete: if isAdmin();
    }

    // ── Arena theme backgrounds ─────────────────────────────────────────────────
    match /assets/arena_theme_assets/{allPaths=**} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin()
                            && request.resource.size < 10 * 1024 * 1024
                            && isImage();
      allow delete: if isAdmin();
    }

    // ── Obstacle sprites ────────────────────────────────────────────────────────
    match /assets/obstacle_assets/{allPaths=**} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin()
                            && request.resource.size < 5 * 1024 * 1024
                            && isImage();
      allow delete: if isAdmin();
    }

    // ── Turret sprites ──────────────────────────────────────────────────────────
    match /assets/turret_assets/{allPaths=**} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin()
                            && request.resource.size < 5 * 1024 * 1024
                            && isImage();
      allow delete: if isAdmin();
    }

    // ── Water body textures ─────────────────────────────────────────────────────
    match /assets/water_body_assets/{allPaths=**} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin()
                            && request.resource.size < 5 * 1024 * 1024
                            && isImage();
      allow delete: if isAdmin();
    }

    // ── Portal sprites ──────────────────────────────────────────────────────────
    match /assets/portal_assets/{allPaths=**} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin()
                            && request.resource.size < 5 * 1024 * 1024
                            && isImage();
      allow delete: if isAdmin();
    }

    // ── Sound assets ────────────────────────────────────────────────────────────
    match /assets/sound_assets/{allPaths=**} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin()
                            && request.resource.size < 20 * 1024 * 1024
                            && isAudio();
      allow delete: if isAdmin();
    }

    // ── Stadium images ──────────────────────────────────────────────────────────
    match /stadiums/{allPaths=**} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin()
                            && request.resource.size < 10 * 1024 * 1024
                            && isImage();
      allow delete: if isAdmin();
    }

    // ── 2.5D Part images (uploaded by admin under parts/{collection}/{partId}/) ──
    match /parts/{allPaths=**} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin()
                            && request.resource.size < 5 * 1024 * 1024
                            && isImage();
      allow delete: if isAdmin();
    }

    // ── Catch-all: deny everything else ────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
